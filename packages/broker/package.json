{
  "name": "@brainst0rm/broker",
  "version": "0.13.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./daemon": {
      "types": "./dist/daemon.d.ts",
      "import": "./dist/daemon.js"
    }
  },
  "bin": {
    "brainstorm-broker": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@brainst0rm/shared": "0.13.0",
    "better-sqlite3": "^11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "description": "Localhost peer broker for cross-session coordination between storm CLI instances",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/justinjilg/brainstorm.git",
    "directory": "packages/broker"
  }
}
