+
+import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';
+import { ProjectManager } from '../manager.js';
+import { ProjectRepository, ProjectMemoryRepository } from '../repository.js';
+import type Database from 'better-sqlite3';
+import { existsSync, readFileSync } from 'node:fs';
+
+// Mock the external dependencies
+vi.mock('better-sqlite3');
+vi.mock('../repository.js');
+vi.mock('node:fs', () => ({
+  existsSync: vi.fn(),
+  readdirSync: vi.fn(),
+  statSync: vi.fn(),
+  readFileSync: vi.fn(),
+}));
+
+describe('ProjectManager', () => {
+  let mockDb: Database.Database;
+  let projectManager: ProjectManager;
+
+  beforeEach(() => {
+    mockDb = {} as Database.Database;
+    projectManager = new ProjectManager(mockDb);
+  });
+
+  afterEach(() => {
+    vi.clearAllMocks();
+  });
+
+  it('should throw an error if the path does not exist during registration', () => {
+    vi.mocked(existsSync).mockReturnValue(false);
+
+    const nonExistentPath = '/non/existent/path';
+    expect(() => projectManager.register(nonExistentPath)).toThrowError(
+      `Path does not exist: ${nonExistentPath}`
+    );
+  });
+});
