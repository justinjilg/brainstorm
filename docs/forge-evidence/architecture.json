  "scalabilityBottlenecks": [
    {
      "type": "synchronous_io",
      "location": "packages/core/src/memory/dream-runner.ts",
      "description": "readFileSync, writeFileSync, statSync, readdirSync, unlinkSync, mkdirSync used in memory operations"
    },
    {
      "type": "synchronous_io",
      "location": "packages/core/src/memory/manager.ts",
      "description": "readFileSync, writeFileSync, readdirSync, statSync, unlinkSync, mkdirSync used for memory file management"
    },
    {
      "type": "synchronous_io",
      "location": "packages/cli/src/bin/brainstorm.ts",
      "description": "execFileSync used for git operations and shell command dispatch in multiple code paths"
    },
    {
      "type": "synchronous_io",
      "location": "packages/cli/src/init/detect.ts",
      "description": "existsSync and readFileSync used during project detection at startup"
    },
    {
      "type": "synchronous_io",
      "location": "packages/cli/src/init/generate.ts",
      "description": "existsSync, readFileSync, writeFileSync, mkdirSync used during project file generation"
    },
    {
      "type": "unbounded_queue",
      "location": "packages/core/src/agent/loop.ts:242",
      "description": "taskEventQueue is an unbounded Array with .push(); no max-size cap; drained via shift() in the yield loop"
    },
    {
      "type": "unbounded_push",
      "location": "packages/core/src/agent/loop.ts",
      "description": "170 unbounded .push() calls across core/src identified; hot paths include agent loop stream parts and tool result accumulation"
    },
    {
      "type": "sqlite_single_writer",
      "location": "packages/db/src/client.ts",
      "description": "WAL mode enabled (journal_mode = WAL), foreign_keys = ON; better-sqlite3 is synchronous and single-process — no concurrent write scaling"
    }
  ],
  "stateMachines": [
    {
      "name": "DaemonController",
      "source": "packages/core/src/daemon/controller.ts",
      "states": ["running", "sleeping", "paused", "stopped"],
      "transitions": 9,
