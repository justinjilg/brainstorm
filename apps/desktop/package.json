{
  "name": "@brainst0rm/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite --port 1420 & sleep 2 && electron .",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "npx playwright test",
    "dist": "vite build && tsc -p electron/tsconfig.json && electron-builder"
  },
  "build": {
    "appId": "com.brainstorm.desktop",
    "productName": "Brainstorm",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/dist/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    }
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource/geist": "^5.2.8",
    "@types/react-syntax-highlighter": "^15.5.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
