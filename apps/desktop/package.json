{
  "name": "@brainst0rm/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Brainstorm Desktop — governed AI control plane",
  "author": "Brainstorm <justinjilg@users.noreply.github.com>",
  "type": "module",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && (vite --port 1420 & sleep 2 && electron .)",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -p electron/tsconfig.json && cp electron/preload.cjs electron/dist/preload.cjs",
    "preview": "vite preview",
    "test": "npx playwright test",
    "test:live": "npm run build:electron && npx playwright test --config tests-live/playwright.live.config.ts",
    "test:protocol": "npx vitest run --config vitest.config.ts",
    "dist": "vite build && npm run build:electron && electron-builder",
    "dist:unsigned": "vite build && npm run build:electron && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "build": {
    "appId": "com.brainstorm.desktop",
    "productName": "Brainstorm",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/dist/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "publish": {
      "provider": "github",
      "owner": "justinjilg",
      "repo": "brainstorm"
    }
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/figtree": "^5.2.10",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/geist": "^5.2.8",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@types/react-syntax-highlighter": "^15.5.13",
    "electron-updater": "^6.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
