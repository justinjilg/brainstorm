{
  "name": "brainstorm",
  "private": true,
  "description": "Governed control plane for AI-managed infrastructure. Connect AI operators to your product ecosystem through a standardized protocol.",
  "keywords": [
    "ai",
    "cli",
    "llm",
    "mcp",
    "agent",
    "routing",
    "infrastructure",
    "control-plane",
    "ai-ops",
    "model-context-protocol",
    "thompson-sampling"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/justinjilg/brainstorm.git"
  },
  "homepage": "https://brainstorm.co",
  "author": "Justin Jilg <jj@brainstorm.co>",
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:abort-signal": "node scripts/lint-abort-signal-timeout.mjs",
    "test": "turbo run test",
    "test:dogfood": "npx tsx tests/dogfood/run-dogfood.ts",
    "test:workflow": "npx tsx tests/workflow-demo/run-demo.ts",
    "typecheck": "turbo run typecheck",
    "postinstall": "npm rebuild better-sqlite3",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "sbom": "node scripts/generate-sbom.mjs",
    "setup:tooling": "node scripts/setup-tooling.mjs",
    "setup:tooling:dry": "node scripts/setup-tooling.mjs --dry-run"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "dependency-cruiser": "17.3.10",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3",
    "turbo": "^2",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48"
  },
  "overrides": {
    "dompurify": ">=3.4.0",
    "hono": ">=4.12.14"
  }
}
