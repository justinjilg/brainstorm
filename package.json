{
  "name": "brainstorm",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:dogfood": "npx tsx tests/dogfood/run-dogfood.ts",
    "test:workflow": "npx tsx tests/workflow-demo/run-demo.ts",
    "typecheck": "turbo run typecheck",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "sbom": "node scripts/generate-sbom.mjs",
    "setup:tooling": "node scripts/setup-tooling.mjs",
    "setup:tooling:dry": "node scripts/setup-tooling.mjs --dry-run"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3",
    "turbo": "^2",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "lint-staged": {
    "packages/tools/src/builtin/**/*.ts": [
      "npm run --workspace=@brainst0rm/tools export-catalog:check"
    ],
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48"
  }
}
